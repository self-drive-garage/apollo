# Define all coms in DAG streaming.
    module_config {
    module_library : "solo/modules/control/libAckermanRobotKitComponent.so"
    components {
        class_name : "AckermanRobotKitComponent"
        config {
            name : "robot_kit"
            readers {
                channel: "VehicleControlCommand"
            }
        }
      }
    }
